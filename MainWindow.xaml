<Window x:Class="ZipApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZipApp"
        mc:Ignorable="d"
        Title="ZipApp - Modern Zipleme Aracı" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9" FontFamily="Segoe UI">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <Style TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Effect="{DynamicResource ShadowEffect}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="5" ShadowDepth="1" Direction="270" Color="#BBBBBB" Opacity="0.5"/>
        
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/>    <!-- List -->
            <RowDefinition Height="Auto"/> <!-- Bottom Bar -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Bar: Path Selection -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ComboBox IsEditable="True" ItemsSource="{Binding RecentPaths}" 
                      Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                      Grid.Column="0" Margin="0,0,10,0" ToolTip="Dosya yolunu buraya yapıştırın veya listeden seçin"
                      VirtualizingPanel.IsVirtualizing="True">
                 <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Height" Value="40"/>
                    </Style>
                 </ComboBox.Style>
            </ComboBox>
            <Button Content="📁 Gözat" Command="{Binding BrowseCommand}" Grid.Column="1" Width="100"/>
        </Grid>

        <!-- Main List -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0" Effect="{StaticResource ShadowEffect}">
            <ListView ItemsSource="{Binding Files}" BorderThickness="0" Background="Transparent" Margin="5">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="60">
                            <!-- Could add select all header if desired, but keeping simple as requested -->
                            <GridViewColumn.Header>
                                <TextBlock Text="Seç" FontWeight="SemiBold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Ad" Width="400">
                             <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Simple Icons based on Type -->
                                        <TextBlock Text="{Binding Type, StringFormat='{}{0}: '}" Foreground="Gray" Margin="0,0,5,0" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="Tür" Width="100" DisplayMemberBinding="{Binding Type}"/>
                        <GridViewColumn Header="Boyut" Width="100" DisplayMemberBinding="{Binding Size}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Bottom Bar: Zip Action -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Zip Dosya Adı:" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="15" FontWeight="SemiBold" Foreground="#333333"/>
            <TextBox Text="{Binding ZipFileName, Mode=OneWay}" IsReadOnly="True" Background="#F0F0F0" Foreground="#666666" Grid.Column="1" Margin="0,0,15,0" ToolTip="Bu ad değiştirilemez"/>
            <Button Content="📦 Sıkıştır" Command="{Binding ZipCommand}" Grid.Column="2" Width="160" Height="40" Background="#4CAF50">
                 <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0" Background="Transparent">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#666666" FontSize="13"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="150" Height="10" IsIndeterminate="True" 
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             BorderThickness="0" Background="#E0E0E0" Foreground="#2196F3"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
